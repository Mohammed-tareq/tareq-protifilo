{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm i",
  "devCommand": "vite",
  "regions": ["iad1"],
  "functions": {
    "api/**/*": {
      "memory": 2048,
      "maxDuration": 60
    }
  },
  "git": {
    "deploymentEnabled": true
  }
}
